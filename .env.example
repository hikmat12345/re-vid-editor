# MotionForce Frontend — Environment Variables
# Copy to .env.local and fill in your values

# Backend API URL (NestJS server / Lambda URL)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional: AWS region for direct S3 uploads from browser
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET=motionforce-media

# Remotion Lambda (video editor rendering)
# These are read by the existing editor API routes in /app/api/latest/
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_REGION=us-east-1
REMOTION_FUNCTION_NAME=remotion-render
REMOTION_SERVE_URL=
